
DATABASE_URL=mysql://user:password@localhost:3306/ai_blog_platform


JWT_SECRET=your-super-secret-jwt-key-change-this-in-production


JWT_ACCESS_TOKEN_TTL=1d

PORT=3000

NODE_ENV=development


# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# Database
DATABASE_URL=mysql://user:password@localhost:3306/dbname



# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourdomain.com

# Frontend
FRONTEND_URL=http://localhost:3001


# MongoDB for Caching
MONGODB_URI=mongodb://localhost:27017/ai_blog_platform

# Or for MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ai-blog-cache


